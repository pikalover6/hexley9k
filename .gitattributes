# Force LF line endings for shell scripts and text config files.
# Prevents Windows git (core.autocrlf=true) from converting to CRLF,
# which breaks shebangs when run inside Linux/Docker containers.
setup/*         text eol=lf
scripts/*       text eol=lf
docker-build.sh text eol=lf
Dockerfile      text eol=lf
*.sh            text eol=lf
plists/*.plist  text eol=lf

