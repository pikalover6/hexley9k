################################################################################
# USER MANAGEMENT
# Implemented in pure POSIX shell + openssl, exactly replicating pd_injectuser
# without requiring a Darwin chroot or Darwin-specific tools.
################################################################################

mkdir -p "$MOUNT/var/db/dslocal/nodes/Default/users"
mkdir -p "$MOUNT/private/var/db/shadow/hash"

inject_user() {
    _uname="$1"
    _passwd="${2:-$_uname}"
    _shell="${3:-/bin/zsh}"
    _realname="$_uname"

    echo "Creating user: $_uname"

    # -- UUID -----------------------------------------------------------
    _uuid="$(openssl rand 4 | xxd -p -u)-\
$(openssl rand 2 | xxd -p -u)-\
$(openssl rand 2 | xxd -p -u)-\
$(openssl rand 2 | xxd -p -u)-\
$(openssl rand 6 | xxd -p -u)"

    # -- UID ------------------------------------------------------------
    if [ "$_uname" = "root" ]; then
        _uid=0; _gid=0
        _uuid="FFFFEEEE-DDDD-CCCC-BBBB-AAAA00000000"
        _homedir="/var/root"
    else
        # Find max UID in existing plists, start at 1000.
        _maxuid=$(grep -r '<key>uid</key>' \
            "$MOUNT/var/db/dslocal/nodes/Default/users/" 2>/dev/null -A2 \
            | grep '<string>' | grep -oE '[0-9]+' | sort -rn | head -1)
        _uid=$(( (_maxuid < 1000 ? 1000 : _maxuid) + 1 ))
        _gid=$_uid
        _homedir="/Users/$_uname"
    fi

    # -- User plist -----------------------------------------------------
    _plist="$MOUNT/var/db/dslocal/nodes/Default/users/${_uname}.plist"
    cat > "$_plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>authentication_authority</key>
	<array>
		<string>;ShadowHash;</string>
	</array>
	<key>generateduid</key>
	<array>
		<string>${_uuid}</string>
	</array>
	<key>gid</key>
	<array>
		<string>${_gid}</string>
	</array>
	<key>home</key>
	<array>
		<string>${_homedir}</string>
	</array>
	<key>name</key>
	<array>
		<string>${_uname}</string>
	</array>
	<key>passwd</key>
	<array>
		<string>********</string>
	</array>
	<key>realname</key>
	<array>
		<string>${_realname}</string>
	</array>
	<key>shell</key>
	<array>
		<string>${_shell}</string>
	</array>
	<key>uid</key>
	<array>
		<string>${_uid}</string>
	</array>
</dict>
</plist>
PLIST

    # -- Shadow hash file (620 bytes / 1240 hex chars) ------------------
    # Format: 168 zero-hex + 8-hex salt + 40-hex SHA1 + 1024 zero-hex
    _shadow="$MOUNT/private/var/db/shadow/hash/$_uuid"

    # 168 × '0'
    printf '%0168d' 0 > "$_shadow"

    # 4-byte random salt
    _salt=$(openssl rand 4 | xxd -p -u)
    _salt_bin=$(printf '%s' "$_salt" | xxd -r -p)

    # salted SHA-1:  sha1( salt_bytes || password )
    _sha1=$(printf '%s%s' "$_salt_bin" "$_passwd" \
            | openssl dgst -sha1 | awk '{print toupper($NF)}')

    printf '%s%s' "$_salt" "$_sha1" >> "$_shadow"

    # 1024 × '0'  (total so far: 168+8+40 = 216; need 1240 total → 1024 more)
    printf '%01024d' 0 >> "$_shadow"

    # -- Shadow state plist ---------------------------------------------
    _now=$(date -u "+%Y-%m-%dT%H:%M:%SZ")
    cat > "${_shadow}.state" <<SPLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
   <dict>
	<key>CreationDate</key>
	<date>${_now}</date>
	<key>FailedLoginCount</key>
	<integer>0</integer>
	<key>LastLoginDate</key>
	<date>${_now}</date>
	<key>NewPasswordRequired</key>
	<integer>0</integer>
   </dict>
</plist>
SPLIST

    # -- Add to admin group (create group plist if missing) -------------
    _admin_plist="$MOUNT/private/var/db/dslocal/nodes/Default/groups/admin.plist"
    if [ -f "$_admin_plist" ]; then
        if ! grep -q "<string>${_uname}</string>" "$_admin_plist"; then
            sed -i "s|<string>root</string>|<string>root</string><string>${_uname}</string>|" \
                "$_admin_plist"
        fi
    fi

    # -- Create home directory ------------------------------------------
    mkdir -p "$MOUNT${_homedir}"
    chown "${_uid}:${_gid}" "$MOUNT${_homedir}" 2>/dev/null || true
}

