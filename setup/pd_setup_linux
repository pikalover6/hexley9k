#
# pd_setup_linux
#
# Linux / WSL-compatible PureDarwin image assembler.
#
# This script is a line-for-line port of pd_setup that replaces every
# macOS-only utility with a Linux equivalent:
#
#   macOS tool          Linux equivalent           package (Ubuntu/Debian)
#   ─────────────────── ────────────────────────── ──────────────────────────
#   hdid -nomount       losetup -f --show          util-linux (pre-installed)
#   pdisk (APM)         parted (mklabel mac)       parted
#   newfs_hfs           mkfs.hfsplus               hfsprogs
#   mount -t hfs        mount -t hfsplus           hfsprogs / kernel module
#   gnutar              tar (GNU tar)              tar (pre-installed)
#   ditto               rsync -a                   rsync
#   mkisofs (Mach-O)    genisoimage                genisoimage
#   qemu-img (Mach-O)   qemu-img (system)          qemu-utils
#   vsdbutil            (owner flag on mkfs)       hfsprogs
#   launchctl           (no-op on host)            —
#   kextcache           (touch Extensions dir)     —
#   bless               startupfiletool on loop    hfsprogs / own tool below
#
# Package lookup  — pd_setup_linux looks for <name>.root.tar.gz across
# the entire puredarwin.roots/Roots/ tree (all subdirectories, newest
# match wins) instead of the defunct setup/pd_tmp/ download cache.
# Both .tar.gz and .tar.bz2 extensions are tried.
#
# User creation — implemented in pure POSIX shell + openssl + sed,
# exactly replicating pd_injectuser without any Darwin chroot.
#
# Required packages (Ubuntu / Debian / WSL2):
#   sudo apt-get install parted hfsprogs genisoimage qemu-utils \
#                        kpartx rsync openssl
#
# Usage:
#   sudo ./setup/pd_setup_linux output.vmwarevm PureDarwin
#   sudo ./setup/pd_setup_linux output.vmdk      PureDarwin
#   sudo ./setup/pd_setup_linux output.iso       PureDarwin
#
# NOTES:
#   - Must be run as root (loop-device management requires root).
#   - WSL1 does not support loop devices; use WSL2 with:
#       [wsl2]
#       kernelCommandLine = vsyscall=emulate
#     in %USERPROFILE%\.wslconfig and load the loop module:
#       sudo modprobe loop
#

set -e

echo
echo "Set up a bootable PureDarwin system (Linux/WSL)."
echo

################################################################################
# USAGE AND PREFLIGHT TESTS
################################################################################

if [ "$(id -u)" -ne 0 ]; then
    echo "You must be root in order to use $(basename "$0")"
    exit 1
fi

if [ $# -lt 2 ]; then
    echo "Usage: $(basename "$0") output VolumeName"
    echo
    echo "  Create an ISO-compatible raw disk image:"
    echo "    $(basename "$0") puredarwin.iso PureDarwin"
    echo
    echo "  Create a VMware virtual disk:"
    echo "    $(basename "$0") puredarwin.vmdk PureDarwin"
    echo
    echo "  Create a VMware virtual machine package:"
    echo "    $(basename "$0") puredarwin.vmwarevm PureDarwin"
    echo
    exit 1
fi

if [ "$1" = "" ] || [ "$1" = "/" ]; then
    echo "$(basename "$0"): bad output name: $1"
    exit 1
fi

################################################################################
# DEPENDENCY CHECKS
################################################################################

check_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "ERROR: '$1' not found."
        echo "  Install it with:  sudo apt-get install $2"
        exit 1
    fi
}

check_cmd parted       parted
check_cmd losetup      util-linux
check_cmd kpartx       kpartx
check_cmd mkfs.hfsplus hfsprogs
check_cmd genisoimage  genisoimage
check_cmd rsync        rsync
check_cmd openssl      openssl
check_cmd xxd          xxd

QEMUIMG_BIN=""
if command -v qemu-img >/dev/null 2>&1; then
    QEMUIMG_BIN="$(command -v qemu-img)"
fi

################################################################################
# PATHS AND VARIABLES
################################################################################

DIRNAME=$(cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(dirname "$DIRNAME")

# Source shared configuration
# shellcheck source=pd_config
. "$DIRNAME/pd_config"

TARGET="$1"
VOLNAME="$2"
MOUNT="/mnt/puredarwin_setup_$$"

# Roots search paths: newly compiled roots take precedence over older pre-built ones.
# find_root() below searches these in order, returning the first match.
ROOTS_SEARCH_DIRS="
$REPO_ROOT/puredarwin.roots/Roots/9J61pd1
$REPO_ROOT/puredarwin.roots/Roots/9G55pd1
$REPO_ROOT/puredarwin.roots/Roots/9F33pd1
$REPO_ROOT/puredarwin.roots/Roots/9D34
$REPO_ROOT/puredarwin.roots/Roots/9A581
$REPO_ROOT/puredarwin.roots/Roots/pd
"

# Determine output extension via shell parameter expansion (handles multi-dot names).
EXT="${1##*.}"
[ "$EXT" = "$1" ] && EXT=""      # no dot → physical disk path

ELTORITOISO=/tmp/puredarwin_eltorito_$$.iso

# For the .vmwarevm bundle format the script cannot write the raw disk image
# directly to $TARGET on Docker/WSL2 volume mounts (the path may be ghost-
# stuck as a directory due to virtiofs state).  Use a sibling temp file on
# the SAME volume mount (not tmpfs) — virtiofs/NTFS-backed loop devices work
# correctly with guestmount whereas tmpfs-backed ones do not.
if [ "$EXT" = "vmwarevm" ]; then
    RAW_TARGET="${TARGET%.*}_rawdisk.img"
else
    RAW_TARGET="$TARGET"
fi

# Loop-device / partition state for cleanup.
LOOP_DEV=""
LOOP_PART=""

################################################################################
# HELPER: find a root archive by project name.
#
# Searches ROOTS_SEARCH_DIRS for <name>.root.tar.gz and .root.tar.bz2.
# Prints the first match to stdout; returns 1 if not found.
################################################################################
find_root() {
    _name="$1"
    for _dir in $ROOTS_SEARCH_DIRS; do
        for _ext in tar.gz tar.bz2; do
            _f="$_dir/${_name}.root.${_ext}"
            if [ -f "$_f" ]; then
                echo "$_f"
                return 0
            fi
        done
    done
    return 1
}

################################################################################
# HELPER: extract a root archive into $MOUNT.
################################################################################
extract_root() {
    _name="$1"
    _path=$(find_root "$_name") || {
        echo "  WARNING: root not found for '$_name' – skipping"
        return 0
    }
    echo " * $_name  ($( basename "$_path" ))"
    tar xpf "$_path" -C "$MOUNT" >> "$MOUNT/private/var/log/pd_setup.log" 2>&1
}

################################################################################
# HELPER: extract a root archive and fail hard if missing (required package).
################################################################################
extract_root_required() {
    _name="$1"
    _path=$(find_root "$_name") || {
        echo "ERROR: required root '$_name' not found in puredarwin.roots/Roots/."
        echo "       Run './setup/pd_build_linux' to build it from source first."
        exit 1
    }
    echo " * $_name  ($( basename "$_path" ))"
    tar xpf "$_path" -C "$MOUNT" >> "$MOUNT/private/var/log/pd_setup.log" 2>&1
}

################################################################################
# INFORMATION
################################################################################

echo "Darwin release : $DARWIN_RELEASE"
echo "Architecture   : $ARCH"
echo "PureDarwin     : $PUREDARWIN_RELEASE"
echo
echo "Target         : $TARGET"
echo "Volume name    : $VOLNAME"
echo

################################################################################
# WARNINGS
################################################################################

echo "WARNING! this will destroy all data on $1"
printf "Continue? y[n] "
read -r CONT
if [ "$CONT" != "y" ]; then exit 1; fi

echo "WARNING! Are you sure?"
printf "Continue? y[n] "
read -r CONT
if [ "$CONT" != "y" ]; then exit 1; fi

if [ -e "$1" ]; then
    echo "WARNING! '$1' is going to be rewritten"
    printf "Continue? y[n] "
    read -r CONT
    if [ "$CONT" != "y" ]; then echo "Aborted."; exit 1; fi
fi

echo
echo "OK, You have been warned.."
echo

# Remove any pre-existing target (file, directory, or partial bundle).
# On Docker/Windows volume mounts the previous mv+mkdir dance can leave
# a stale directory entry that persists between container runs.
rm -rf "$TARGET" "$RAW_TARGET" 2>/dev/null || true

# Clean up any loop devices left over from a previous failed assembly run.
# (Needed because loop+kpartx state is shared across container restarts.)
losetup -a 2>/dev/null \
  | grep -v 'docker-desktop\|docker-wsl-cli' \
  | awk -F: '{print $1}' \
  | while read -r _ld; do
      kpartx -d "$_ld" 2>/dev/null || true
      losetup -d "$_ld" 2>/dev/null || true
    done

################################################################################
# CLEANUP / TRAP
################################################################################

# Track whether guestmount was used (needs guestunmount instead of umount).
USE_GUESTMOUNT=0
# Tmpfs copy of HFS+ partition used by guestmount (avoids virtiofs O_DIRECT issue).
HFS_IMG=""

mr_proper() {
    set +e
    # Unmount first, then tear down device-mapper/loop (order matters).
    if mountpoint -q "$MOUNT" 2>/dev/null; then
        if [ "$USE_GUESTMOUNT" = "1" ]; then
            guestunmount "$MOUNT" 2>/dev/null || true
        else
            umount -f "$MOUNT" 2>/dev/null || fusermount -u "$MOUNT" 2>/dev/null
        fi
    fi
    if [ -n "$LOOP_PART" ]; then
        kpartx -d "$LOOP_DEV" >/dev/null 2>&1
    fi
    if [ -n "$LOOP_DEV" ]; then
        losetup -d "$LOOP_DEV" 2>/dev/null
    fi
    rm -f "$ELTORITOISO"
    rm -f "${HFS_IMG:-}" 2>/dev/null || true
    # Clean up temporary raw image (used when output is .vmwarevm bundle).
    [ "${RAW_TARGET:-}" != "${TARGET:-}" ] && rm -f "$RAW_TARGET" 2>/dev/null || true
    rmdir "$MOUNT" 2>/dev/null || true
    set -e
}

trap 'echo; echo "Interrupted — cleaning up."; mr_proper; exit 1' INT TERM

################################################################################
# BOOTLOADER PATH
################################################################################

# Default bootloader: DFE bootloader v5.0.132_dfe_r146 (Apple boot-132)
BOOTi386=$DIRNAME/pd_setup_files/boot/i386/

# Chameleon bootloader (default: yes)
if [ "$ADD_CHAMELEON" != "n" ]; then
    T_CHAMELEON_RELEASE=""
    [ "$ADD_CHAMELEON_RC1" = "y" ] && T_CHAMELEON_RELEASE="Chameleon-2.0-RC1-r431-bin"
    [ "$ADD_CHAMELEON_RC2" = "y" ] && T_CHAMELEON_RELEASE="Chameleon-2.0-RC2-r640-bin"
    [ "$ADD_CHAMELEON_RC3" = "y" ] && T_CHAMELEON_RELEASE="Chameleon-2.0-RC3-r658-bin"
    [ "$ADD_CHAMELEON_RC4" = "y" ] && T_CHAMELEON_RELEASE="Chameleon-2.0-RC4-r684-bin"

    if [ -n "$T_CHAMELEON_RELEASE" ]; then
        echo "Extracting Chameleon bootloader ($T_CHAMELEON_RELEASE)"
        _cham_root=$(find_root "$T_CHAMELEON_RELEASE") || {
            echo "ERROR: Chameleon root '$T_CHAMELEON_RELEASE' not found."
            exit 1
        }
        tar xpf "$_cham_root" -C "$DIRNAME/pd_setup_files/" \
            --wildcards '*i386*'
        BOOTi386=$DIRNAME/pd_setup_files/$T_CHAMELEON_RELEASE/i386/
    fi
fi

BOOT0="boot0"    # MBR
BOOT1H="boot1h"  # HFS+ partition boot sector
BOOT="boot"      # Stage 2 (Chameleon / boot2)
CDBOOT="cdboot"  # El Torito CD-ROM boot image

################################################################################
# IMAGE CREATION (ISO / VMDK / VMWAREVM)
################################################################################

if [ -n "$EXT" ]; then

    # ------------------------------------------------------------------
    # 1. Decide disk image size.
    # ------------------------------------------------------------------
    SIZE="1618"     # MiB — full release
    if [ "$ADD_RELEASE_NANO" = "y" ]; then
        if [ "$PUREDARWIN_RELEASE" = "nano" ]; then
            SIZE="150"
        else
            SIZE="640"
        fi
    fi

    # HFS+ partition starts at sector 63 (one-cylinder gap, classic PC MBR layout).
    # This exactly matches the Brain Transplant Edition VMDK (PDXMASNBE01) which
    # is confirmed to boot on VMware Workstation/Fusion with Chameleon RC4 r684.
    # Chameleon boot0 reads the LBA start directly from the MBR partition entry
    # at bytes 446+8 and issues INT 13h to load boot1h from that sector.
    HFS_START=63

    # ------------------------------------------------------------------
    # 2. Pre-build libguestfs appliance BEFORE creating any loop devices.
    # ------------------------------------------------------------------
    if command -v guestmount >/dev/null 2>&1 && \
       ! (modprobe hfsplus 2>/dev/null && grep -q hfsplus /proc/filesystems 2>/dev/null); then
        echo "Pre-building libguestfs appliance (before disk creation)..."
        _ub_kernel=$(ls /boot/vmlinuz-5.15.0-*-generic 2>/dev/null | sort -V | tail -1)
        if [ -n "$_ub_kernel" ]; then
            export LIBGUESTFS_KERNEL="$_ub_kernel"
        fi
        rm -rf /var/tmp/.guestfs-0/ 2>/dev/null || true
        LIBGUESTFS_BACKEND=direct guestfish -a /dev/null run : shutdown 2>/dev/null || true
        echo "  Appliance pre-built."
    fi

    # ------------------------------------------------------------------
    # 3. Create raw disk image.
    # ------------------------------------------------------------------
    echo "Creating raw disk image: $RAW_TARGET  (${SIZE} MiB)"
    dd if=/dev/zero of="$RAW_TARGET" bs=1M count="$SIZE" status=progress

    # ------------------------------------------------------------------
    # 4. Partition with MBR (msdos) + single HFS+ partition at sector 63.
    #
    #    sfdisk is used directly on the raw image file.  The format string
    #    "start,,type,bootable" maps to: start sector, size (all remaining),
    #    partition type (0xAF = HFS+), bootable flag (*).
    #
    #    This produces a partition table byte-compatible with the Brain
    #    Transplant Edition VMDK which uses macOS fdisk -a hfs (sector 63,
    #    type AF, bootable).
    # ------------------------------------------------------------------
    echo "Partitioning: MBR, HFS+ at sector $HFS_START"
    printf '%s\n' "${HFS_START},,af,*" | sfdisk --force "$RAW_TARGET" 2>/dev/null || \
    printf '%s\n' "${HFS_START},,af,*" | sfdisk "$RAW_TARGET"

    # ------------------------------------------------------------------
    # 5. Install Chameleon boot0 into MBR bytes 0-439.
    #
    #    The MBR sector layout is:
    #      Bytes   0-439  bootstrap code (boot0)
    #      Bytes 440-443  disk signature (written by sfdisk, preserved)
    #      Bytes 444-445  reserved 0x0000 (preserved)
    #      Bytes 446-509  partition table (written by sfdisk above)
    #      Bytes 510-511  boot signature 0x55AA (written by sfdisk)
    #
    #    Writing exactly 440 bytes of boot0 overwrites only the bootstrap
    #    code, leaving the partition table and signature intact.
    #
    #    Boot chain:
    #      BIOS → boot0 (bytes 0-439)
    #             → scans partition table for type-0xAF entry
    #             → finds HFS+ starting at sector 63
    #             → INT 13h: loads 512 bytes from sector 63 → boot1h
    #             → boot1h scans HFS+ catalog for /boot
    #             → /boot (Chameleon stage 2) loads mach_kernel.voodoo
    #             → Darwin 9 kernel starts
    # ------------------------------------------------------------------
    echo "Installing Chameleon boot0 to MBR (440 bytes)..."
    dd if="$BOOTi386/$BOOT0" of="$RAW_TARGET" bs=440 count=1 conv=notrunc 2>/dev/null
    echo "boot0 installed."

    # ------------------------------------------------------------------
    # 7. Format HFS+ directly into a local tmpfs file.
    #
    #    Rationale: writing via a loop device backed by the virtiofs mount
    #    (RAW_TARGET on the Docker bind-mount) leads to a page-cache
    #    coherency bug: the guest kernel's block-device cache and virtiofs's
    #    file cache diverge after sync(), so reads from the block device
    #    return the original zeros rather than the mkfs-written metadata.
    #
    #    By formatting directly into a tmpfs file we stay entirely in the
    #    guest kernel's page cache — no virtiofs involved — and QEMU (via
    #    guestmount) can read the fresh HFS+ volume header reliably.
    #    Afterwards we write the populated image back into RAW_TARGET with a
    #    plain dd (write-only, no readback from virtiofs).
    # ------------------------------------------------------------------
    HFS_SIZE=$(( SIZE * 1024 * 1024 - HFS_START * 512 ))
    HFS_IMG="/tmp/puredarwin_hfs_$$.img"
    echo "Creating HFS+ partition image in tmpfs: $HFS_IMG  ($HFS_SIZE bytes)"
    # Sparse truncate: allocates no disk space for the zero-filled regions.
    truncate -s "$HFS_SIZE" "$HFS_IMG"

    if [ "$ADD_HFS_JOURNAL" != "n" ]; then
        echo "Formatting $HFS_IMG as journaled HFS+ ($VOLNAME)"
        mkfs.hfsplus -J -v "$VOLNAME" "$HFS_IMG"
    else
        echo "Formatting $HFS_IMG as HFS+ ($VOLNAME)"
        mkfs.hfsplus -v "$VOLNAME" "$HFS_IMG"
    fi
    echo "HFS+ magic after mkfs: $(dd if="$HFS_IMG" bs=1 skip=1024 count=2 2>/dev/null | xxd -p) (expect 482b)"

    # ------------------------------------------------------------------
    # 8. Install boot1h to the HFS+ partition boot sector (byte 0 of HFS_IMG).
    #
    #    boot1h may span more than one 512-byte sector (Chameleon RC4's
    #    boot1h is 1024 bytes = 2 sectors).  boot0 loads only the first
    #    sector and jumps to it; that first sector then re-loads the
    #    remainder from disk.  We must write all sectors of boot1h so
    #    the self-loader finds the correct code at sector 1 of the
    #    HFS+ partition rather than HFS+ metadata zeros.
    #    HFS+ reserves the first 1024 bytes (sectors 0-1) as "boot blocks"
    #    (normally empty); overwriting them with boot1h is safe.
    # ------------------------------------------------------------------
    _boot1h_sectors=$(( ( $(stat -c '%s' "$BOOTi386/$BOOT1H") + 511 ) / 512 ))
    echo "Installing boot1h to HFS+ partition boot sector ($_boot1h_sectors sector(s))"
    dd if="$BOOTi386/$BOOT1H" of="$HFS_IMG" bs=512 count="$_boot1h_sectors" conv=notrunc

    # HFS_IMG is already on tmpfs (formatted directly above).  No sync needed
    # for virtiofs because the loop device was detached before mkfs.

    # ------------------------------------------------------------------
    # 9. Mount HFS+ and begin populating.
    #    Try in order: kernel driver → hfsfuse (FUSE, read-only warning) →
    #    guestmount (libguestfs/QEMU appliance, writable, no kernel needed).
    # ------------------------------------------------------------------
    mkdir -p "$MOUNT"
    if mount -t hfsplus "$HFS_IMG" "$MOUNT" 2>/dev/null; then
        echo "Mounted $HFS_IMG on $MOUNT (kernel hfsplus)"
    elif command -v guestmount >/dev/null 2>&1; then
        echo "Kernel hfsplus unavailable — mounting via guestmount (libguestfs/QEMU)"
        echo "Note: without KVM this may be slow, but is fully writable."
        # Force libguestfs to use the INSTALLED Ubuntu kernel (has CONFIG_HFSPLUS_FS=m),
        # NOT the running WSL2 kernel which lacks HFS+ support.
        _ub_kernel=$(ls /boot/vmlinuz-5.15.0-*-generic 2>/dev/null | sort -V | tail -1)
        if [ -n "$_ub_kernel" ]; then
            echo "  Using kernel: $_ub_kernel"
            export LIBGUESTFS_KERNEL="$_ub_kernel"
        fi
        # HFS_IMG is a local tmpfs file (formatted by mkfs.hfsplus above).
        # QEMU opens it with buffered I/O (no O_DIRECT for regular files), so it
        # reads the fresh HFS+ metadata directly from the page cache.
        # "rw,force" is required: hfsplus defaults to read-only and force is
        # needed when the journal appears dirty (expected for a newly-formatted vol).
        echo "  HFS+ check: $(dd if="$HFS_IMG" bs=1 skip=1024 count=2 2>/dev/null | xxd -p) (expect 482b)"
        LIBGUESTFS_BACKEND=direct guestmount --rw -a "$HFS_IMG" -m "/dev/sda:/:rw,force:hfsplus" "$MOUNT"
        USE_GUESTMOUNT=1
        echo "Mounted HFS+ partition via guestmount on $MOUNT"
    elif command -v hfsfuse >/dev/null 2>&1; then
        echo "WARNING: hfsfuse is read-only — population will fail."
        echo "         Install libguestfs-tools for writable HFS+ support."
        hfsfuse -o allow_other "$HFS_IMG" "$MOUNT"
    else
        echo "ERROR: Cannot mount HFS+. Install libguestfs-tools in the Docker image."
        mr_proper
        exit 1
    fi

    # Copy stage-2 Chameleon loader to the volume root.
    echo "Installing stage-2 loader (boot) to volume root"
    cp "$BOOTi386/$BOOT" "$MOUNT/"

else
    # Physical-disk path (not supported on Linux — use pd_setup on macOS).
    echo "ERROR: Physical disk targets are not supported by pd_setup_linux."
    echo "       Use pd_setup on a macOS host for physical disk installation."
    exit 1
fi

################################################################################
# DISABLE SPOTLIGHT
################################################################################

echo "Disabling Spotlight indexation"
touch "$MOUNT/.metadata_never_index"

################################################################################
# LOG DIRECTORY
################################################################################

mkdir -p "$MOUNT/private/var/log/"
echo "Installing packages on '${MOUNT}'..."

################################################################################
# BINARY ROOTS / PREBUILT FILESYSTEM DEPLOYMENT
################################################################################

if [ -n "$PREBUILT_FILESYSTEM" ]; then
    echo "Using prebuilt filesystem from: $PREBUILT_FILESYSTEM"
    rsync -aH --no-atimes "$PREBUILT_FILESYSTEM/" "$MOUNT/"
else
    #
    # Extract each project listed in the active BINARYROOTS_LIST_FILE
    # (pd_roots, pd_roots.nano, or pd_roots.bootstrap — set by pd_config).
    #
    while IFS= read -r PROJECT; do
        [ -z "$PROJECT" ] && continue

        _path=$(find_root "$PROJECT") || {
            echo "  MISSING root for '$PROJECT' — skipping"
            continue
        }

        echo " * $PROJECT  ($(basename "$_path"))"
        if [ "$ADD_RELEASE_NANO" = "y" ]; then
            tar xpf "$_path" -C "$MOUNT" \
                --exclude '*svn*' \
                --exclude '*/include/*' \
                --exclude '/Developer' \
                --exclude '/AppleInternal' \
                --exclude '/usr/lib/libSystem.B_debug.dylib' \
                --exclude '/usr/lib/libSystem.B_profile.dylib' \
                --exclude '*.h' \
                >> "$MOUNT/private/var/log/pd_setup.log" 2>&1
        else
            tar xpf "$_path" -C "$MOUNT" \
                >> "$MOUNT/private/var/log/pd_setup.log" 2>&1
        fi
    done < "$DIRNAME/$BINARYROOTS_LIST_FILE"

    echo

    # ----------------------------------------------------------------
    # OPTIONAL PACKAGES (mirrors pd_setup logic)
    # ----------------------------------------------------------------

    # Voodoo kernel (default: y)
    if [ "$ADD_VOODOO_XNU" != "n" ]; then
        extract_root Voodoo_kernel
        [ -f "$MOUNT/mach_kernel" ] && mv "$MOUNT/mach_kernel" "$MOUNT/mach_kernel.origin"
        if [ "$ADD_VOODOO_XNU_9_5_0" != "n" ] && [ -f "$MOUNT/mach_kernel.voodoo.9.5" ]; then
            cp "$MOUNT/mach_kernel.voodoo.9.5" "$MOUNT/mach_kernel"
        fi
        if [ "$ADD_VOODOO_XNU_9_7_0" = "y" ] && [ -f "$MOUNT/mach_kernel.voodoo.9.7" ]; then
            cp "$MOUNT/mach_kernel.voodoo.9.7" "$MOUNT/mach_kernel"
        fi
    fi

    [ "$ADD_VOODOO_XNU_SPEEDSTEP" = "y" ] && {
        extract_root VoodooIntelEnhancedSpeedStep
        chown -R root:0 "$MOUNT/System/Library/Extensions/IntelEnhancedSpeedStep.kext" 2>/dev/null || true
        chmod -R 755    "$MOUNT/System/Library/Extensions/IntelEnhancedSpeedStep.kext" 2>/dev/null || true
    }

    [ "$ADD_VOODOO_POWER_MINI" = "y" ]      && extract_root VoodooPowerMini

    [ "$ADD_VOODOO_PS2CONTROLLER" != "n" ]  && extract_root VoodooPS2Controller

    if [ "$ADD_DFE_PS2CONTROLLER" = "y" ]; then
        extract_root ACPIPS2Nub
        extract_root ApplePS2Controller
    fi

    if [ "$ADD_VMWARE" != "n" ]; then
        echo " * VMware-Drivers-OpenSource.zip"
