################################################################################
# CONVERT TO OUTPUT FORMAT
################################################################################

if [ "$DARWIN_RELEASE" = "10" ]; then
    T_GUESTOS="darwin10"
else
    T_GUESTOS="darwin"
fi

T_BASE="${TARGET%.*}"
T_EXT="$EXT"

case $T_EXT in

    # ----------------------------------------------------------------
    # ISO: the raw Apple Partition Map image is already ISO-compatible.
    # ----------------------------------------------------------------
    iso)
    echo "Output: $TARGET  (raw APM disk image / ISO-compatible)"
    ;;

    # ----------------------------------------------------------------
    # VMDK: convert with qemu-img.
    # ----------------------------------------------------------------
    vmdk)
    if [ -z "$QEMUIMG_BIN" ]; then
        echo "ERROR: qemu-img not found; cannot create .vmdk."
        echo "       Install qemu-utils:  sudo apt-get install qemu-utils"
        exit 1
    fi
    _iso="${T_BASE}.iso"
    mv "$TARGET" "$_iso"
    echo "Converting to VMware VMDK..."
    "$QEMUIMG_BIN" convert -O vmdk "$_iso" "$TARGET"
    rm -f "$_iso"
    ;;

    # ----------------------------------------------------------------
    # VMWAREVM: bundle directory with VMDK + VMX.
    # ----------------------------------------------------------------
    vmwarevm)
    if [ -z "$QEMUIMG_BIN" ]; then
        echo "ERROR: qemu-img not found; cannot create .vmwarevm."
        echo "       Install qemu-utils:  sudo apt-get install qemu-utils"
        exit 1
    fi
    _name=$(basename "$T_BASE")
    _iso="${_name}.iso"
    _vmdk="${_name}.vmdk"
    _vmx="${_name}.vmx"

    mv "$TARGET" "$_iso"
    mkdir -p "$TARGET"
    mv "$_iso" "$TARGET/$_iso"

    if [ "$ADD_VMWARE_VMDK" != "n" ]; then
        echo "Converting to VMware VMDK..."
        "$QEMUIMG_BIN" convert -O vmdk "$TARGET/$_iso" "$TARGET/$_vmdk"
    fi

    _date=$(date +"%y%m%d%H%M")
    cat > "$TARGET/$_vmx" <<VMX
.encoding = "UTF-8"
bios.bootDelay = "5000"
config.version = "8"
displayName = "${_date} ${DARWIN_RELEASE} / ${ARCH} / $PUREDARWIN_RELEASE"
ehci.present = "TRUE"
ethernet0.linkStatePropagation.enable = "FALSE"
ethernet0.present = "TRUE"
ethernet0.virtualDev = "e1000"
ethernet0.wakeOnPcktRcv = "FALSE"
floppy0.present = "FALSE"
ft.secondary0.enabled = "TRUE"
guestOS = "$T_GUESTOS"
ich7m.present = "TRUE"
ide0:0.fileName = "$_vmdk"
ide0:0.present = "TRUE"
ide0:0.redo = ""
ide1:0.autodetect = "TRUE"
ide1:0.deviceType = "cdrom-image"
ide1:0.fileName = "$_iso"
ide1:0.present = "TRUE"
keyboardAndMouseProfile = "macProfile"
memsize = "128"
nvram = "${_name}.nvram"
pciBridge0.present = "TRUE"
pciBridge4.functions = "8"
pciBridge4.present = "TRUE"
pciBridge4.virtualDev = "pcieRootPort"
pciBridge5.functions = "8"
pciBridge5.present = "TRUE"
pciBridge5.virtualDev = "pcieRootPort"
pciBridge6.functions = "8"
pciBridge6.present = "TRUE"
pciBridge6.virtualDev = "pcieRootPort"
pciBridge7.functions = "8"
pciBridge7.present = "TRUE"
pciBridge7.virtualDev = "pcieRootPort"
powerType.powerOff = "soft"
powerType.powerOn = "soft"
powerType.reset = "soft"
powerType.suspend = "soft"
printers.enabled = "FALSE"
roamingVM.exitBehavior = "go"
scsi0.present = "TRUE"
scsi0.virtualDev = "lsilogic"
scsi0:0.fileName = ""
scsi0:0.present = "FALSE"
serial0.fileType = "thinprint"
serial0.present = "FALSE"
smc.present = "TRUE"
tools.syncTime = "TRUE"
tools.upgrade.policy = "upgradeAtPowerCycle"
usb.generic.autoconnect = "FALSE"
usb.present = "TRUE"
virtualHW.productCompatibility = "hosted"
virtualHW.version = "7"
vmci0.present = "TRUE"
VMX

    if [ "$ADD_VMWARE_IDE_DRIVE" = "y" ] && [ -n "$QEMUIMG_BIN" ]; then
        "$QEMUIMG_BIN" create -f vmdk "$TARGET/second.vmdk" 2048M
        cat >> "$TARGET/$_vmx" <<VMX
ide0:1.present = "TRUE"
ide0:1.fileName = "second.vmdk"
ide0:1.redo = ""
VMX
    fi

    chmod -R 777 "$TARGET"
    chown -R 501:staff "$TARGET" 2>/dev/null || true
    ;;

    *)
    echo "Output written to $TARGET  (raw APM disk image)."
    ;;
esac

