        _qemu_sys=$(command -v qemu-img 2>/dev/null || true)
        _qemu_bin=${_qemu_sys:-"$QEMUIMG_BIN"}
        "$_qemu_bin" convert -O vmdk "$RAW_TARGET" "$_tmp_work/$_vmdk"
    fi

    _date=$(date +"%y%m%d%H%M")
    cat > "$_tmp_work/$_vmx" <<VMX
