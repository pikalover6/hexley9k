fi

T_BASE="${TARGET%.*}"
T_EXT="$EXT"

case $T_EXT in

    # ----------------------------------------------------------------
    # ISO: the raw Apple Partition Map image is already ISO-compatible.
    # ----------------------------------------------------------------
    iso)
    echo "Output: $TARGET  (raw APM disk image / ISO-compatible)"
    ;;

    # ----------------------------------------------------------------
    # VMDK: convert with qemu-img.
    # ----------------------------------------------------------------
    vmdk)
    if [ -z "$QEMUIMG_BIN" ]; then
        echo "ERROR: qemu-img not found; cannot create .vmdk."
        echo "       Install qemu-utils:  sudo apt-get install qemu-utils"
        exit 1
    fi
    _iso="${T_BASE}.iso"
    mv "$TARGET" "$_iso"
    echo "Converting to VMware VMDK..."
    "$QEMUIMG_BIN" convert -O vmdk "$_iso" "$TARGET"
    rm -f "$_iso"
    ;;

    # ----------------------------------------------------------------
    # VMWAREVM: bundle directory with VMDK + VMX.
    # ----------------------------------------------------------------
    vmwarevm)
    if [ -z "$QEMUIMG_BIN" ]; then
        echo "ERROR: qemu-img not found; cannot create .vmwarevm."
        echo "       Install qemu-utils:  sudo apt-get install qemu-utils"
        exit 1
    fi
    _name=$(basename "$T_BASE")
    _iso="${_name}.iso"
    _vmdk="${_name}.vmdk"
    _vmx="${_name}.vmx"

    # On Docker/WSL2 volume mounts (Windows filesystems), 'mv' of large files
    # corrupts the kernel's VFS cache of the file, making it unreadable.
    # Work entirely in /tmp (a native Linux tmpfs) to avoid this:
    #   1. Convert the raw image to VMDK while it is still accessible.
    #   2. Build the bundle in /tmp.
    #   3. Recreate the output directory on the volume mount and copy in.
    _tmp_work="/tmp/pd_vmwarevm_$$"
    rm -rf "$_tmp_work"
    mkdir -p "$_tmp_work"

    if [ "$ADD_VMWARE_VMDK" != "n" ]; then
        echo "Converting to VMware VMDK..."
