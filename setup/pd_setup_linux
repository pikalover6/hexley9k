bios.bootDelay = "5000"
config.version = "8"
firmware = "bios"
displayName = "${_date} ${DARWIN_RELEASE} / ${ARCH} / $PUREDARWIN_RELEASE"
ehci.present = "TRUE"
ethernet0.linkStatePropagation.enable = "FALSE"
ethernet0.present = "TRUE"
ethernet0.virtualDev = "e1000"
ethernet0.wakeOnPcktRcv = "FALSE"
floppy0.present = "FALSE"
ft.secondary0.enabled = "TRUE"
guestOS = "$T_GUESTOS"
ich7m.present = "TRUE"
ide0:0.fileName = "$_vmdk"
ide0:0.present = "TRUE"
ide0:0.redo = ""
ide1:0.present = "FALSE"
keyboardAndMouseProfile = "macProfile"
memsize = "256"
nvram = "${_name}.nvram"
pciBridge0.present = "TRUE"
pciBridge4.functions = "8"
pciBridge4.present = "TRUE"
pciBridge4.virtualDev = "pcieRootPort"
pciBridge5.functions = "8"
pciBridge5.present = "TRUE"
pciBridge5.virtualDev = "pcieRootPort"
pciBridge6.functions = "8"
pciBridge6.present = "TRUE"
pciBridge6.virtualDev = "pcieRootPort"
pciBridge7.functions = "8"
pciBridge7.present = "TRUE"
pciBridge7.virtualDev = "pcieRootPort"
powerType.powerOff = "soft"
powerType.powerOn = "soft"
powerType.reset = "soft"
powerType.suspend = "soft"
printers.enabled = "FALSE"
roamingVM.exitBehavior = "go"
scsi0.present = "TRUE"
scsi0.virtualDev = "lsilogic"
scsi0:0.fileName = ""
scsi0:0.present = "FALSE"
serial0.fileType = "file"
serial0.fileName = "${_name}.serial.log"
serial0.present = "TRUE"
serial0.tryNoRxLoss = "FALSE"
smc.present = "FALSE"
tools.syncTime = "TRUE"
tools.upgrade.policy = "upgradeAtPowerCycle"
usb.generic.autoconnect = "FALSE"
usb.present = "TRUE"
virtualHW.productCompatibility = "hosted"
virtualHW.version = "7"
vmci0.present = "TRUE"
VMX

    if [ "$ADD_VMWARE_IDE_DRIVE" = "y" ] && [ -n "$QEMUIMG_BIN" ]; then
        "$QEMUIMG_BIN" create -f vmdk "$_tmp_work/second.vmdk" 2048M
        cat >> "$_tmp_work/$_vmx" <<VMX
ide0:1.present = "TRUE"
ide0:1.fileName = "second.vmdk"
ide0:1.redo = ""
VMX
    fi

    # Also include the raw disk image as .iso inside the bundle.
    # Copy from RAW_TARGET (in /tmp) to the bundle — no mv needed.
    # Skip if /tmp doesn't have enough space (1.6 GB); the VM still boots from VMDK.
    if [ "$ADD_VMWARE_ISO_IN_BUNDLE" = "y" ]; then
        cp "$RAW_TARGET" "$_tmp_work/$_iso" 2>/dev/null || \
            echo "NOTE: Raw ISO not included in bundle (insufficient /tmp space)."
    fi
    rm -f "$RAW_TARGET" 2>/dev/null || true

    # Create the final bundle directory on the volume mount and copy in.
    # Note: on Docker/WSL2 volume mounts puredarwin.vmwarevm may appear as a
    # ghost directory (EISDIR) that blocks mkdir but allows cp-into-dir via
    # openat(dirfd).  Use "cp -r src/. dest/" which uses openat and bypasses
    # the path-resolution failure.
    cp -r "$_tmp_work/." "$TARGET/" 2>/dev/null || {
        # Fallback: try mkdir then individual copies.
        mkdir -p "$TARGET" 2>/dev/null || true
        cp "$_tmp_work/$_vmdk" "$TARGET/$_vmdk" 2>/dev/null || true
        cp "$_tmp_work/$_vmx"  "$TARGET/$_vmx"  2>/dev/null || true
    }
    rm -rf "$_tmp_work"

    chmod -R 777 "$TARGET"
    chown -R 501:staff "$TARGET" 2>/dev/null || true
    ;;

    *)
    echo "Output written to $TARGET  (raw APM disk image)."
    ;;
esac

echo "Installation on ${TARGET} complete."
