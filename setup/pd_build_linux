#
# pd_build_linux
#
# Cross-compiles every patched Darwin project in source/ on Linux (or WSL2)
# using clang + cctools-port targeting i386-apple-darwin9, then packages
# the results into .root.tar.gz files in puredarwin.roots/Roots/9J61pd1/.
#
# This script is designed to run INSIDE the Docker container produced by the
# repo's Dockerfile, which already has the toolchain and Darwin SDK set up.
# It can also run directly on any Linux / WSL2 system where the required
# tools are installed manually (see Prerequisites below).
#
# ─────────────────────────────────────────────────────────────────────────────
# Prerequisites (handled automatically by the Dockerfile):
#   • clang  ≥ 11  with -target i386-apple-darwin9 support
#   • cctools-port  (https://github.com/tpoechtrager/cctools-port)
#     Provides: i386-apple-darwin9-{ld,ar,ranlib,strip,lipo,otool,nm}
#   • Darwin 9 SDK headers in $DARWIN_SDK (default /opt/darwin9-sdk)
#     Assembled from XNU 1228.15.4 + Libc 498.1.7 + project headers
#   • Standard build tools: make, autoconf, automake
#
# Manual installation on Ubuntu/Debian (without Docker):
#   sudo apt-get install clang llvm lld make autoconf automake
#   # Build cctools-port:
#   git clone https://github.com/tpoechtrager/cctools-port /opt/cctools-src
#   cd /opt/cctools-src/cctools
#   ./configure --target=i386-apple-darwin9 --prefix=/opt/cctools
#   make -j$(nproc) && sudo make install
#   export PATH=/opt/cctools/bin:$PATH
#   # Set up SDK (see Dockerfile for header assembly steps)
#   export DARWIN_SDK=/opt/darwin9-sdk
#
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   ./setup/pd_build_linux                 # build all patched projects
#   ./setup/pd_build_linux libelf libdwarf # build specific projects
#
# Output: puredarwin.roots/Roots/9J61pd1/<project>.root.tar.gz
#

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")"; pwd)"
case "$SCRIPT_DIR" in
    */setup) REPO_ROOT="$(dirname "$SCRIPT_DIR")" ;;
    *)       REPO_ROOT="$SCRIPT_DIR" ;;
esac

SRC_APPLE="$REPO_ROOT/source/apple"
SRC_THIRD="$REPO_ROOT/source/third_party"
ROOTS_OUT="$REPO_ROOT/puredarwin.roots/Roots/9J61pd1"
BUILD_DIR="/tmp/pd_build_linux_$$"

# Darwin target triple and SDK path (can be overridden in the environment)
DARWIN_TARGET="${DARWIN_TARGET:-i386-apple-darwin9}"
DARWIN_SDK="${DARWIN_SDK:-/opt/darwin9-sdk}"
TOOLCHAIN_PREFIX="${TOOLCHAIN_PREFIX:-/opt/cctools/bin}"

# CC/CXX must be a single executable path for autoconf; flags go in CFLAGS.
# The Dockerfile installs wrapper scripts darwin9-cc / darwin9-c++ that
# embed the -target / --sysroot flags automatically.  Outside Docker, fall
# back to bare clang and put the target flags in CFLAGS / CXXFLAGS.
if command -v darwin9-cc >/dev/null 2>&1; then
    CC="${DARWIN_CC:-darwin9-cc}"
    CXX="${DARWIN_CXX:-darwin9-c++}"
    TARGET_CFLAGS=""
else
    CC="${DARWIN_CC:-clang}"
    CXX="${DARWIN_CXX:-clang++}"
    TARGET_CFLAGS="-target $DARWIN_TARGET -mmacosx-version-min=10.5 --sysroot $DARWIN_SDK"
fi

LD="${DARWIN_LD:-$TOOLCHAIN_PREFIX/${DARWIN_TARGET}-ld}"
AR="${DARWIN_AR:-$TOOLCHAIN_PREFIX/${DARWIN_TARGET}-ar}"
RANLIB="${DARWIN_RANLIB:-$TOOLCHAIN_PREFIX/${DARWIN_TARGET}-ranlib}"
STRIP="${DARWIN_STRIP:-$TOOLCHAIN_PREFIX/${DARWIN_TARGET}-strip}"

export CC CXX LD AR RANLIB STRIP

# Extra include path: framework headers assembled from source trees
EXTRA_CFLAGS="$TARGET_CFLAGS -I$SRC_APPLE/CF -I$SRC_APPLE/IOKitUser -I$DARWIN_SDK/usr/include"

################################################################################
# PREFLIGHT CHECKS
################################################################################

echo "==> pd_build_linux"
echo "    Target  : $DARWIN_TARGET"
echo "    SDK     : $DARWIN_SDK"
echo "    CC      : $CC"
echo "    LD      : $LD"
echo "    CFLAGS  : $EXTRA_CFLAGS"
echo ""

check_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "ERROR: '$1' not found."
        echo "  Either run this inside the Docker container  (./docker-build.sh)"
        echo "  or install the tool manually:  $2"
        exit 1
    fi
}

check_tool clang          "apt-get install clang"
check_tool make           "apt-get install build-essential"
check_tool autoconf       "apt-get install autoconf"

if ! $CC -x c -E - < /dev/null >/dev/null 2>&1 <<'EOF'
int main() { return 0; }
EOF
then
    echo "WARNING: Test compile with '$CC' failed."
    echo "  The Darwin SDK at $DARWIN_SDK may be incomplete."
    echo "  Build will continue but individual projects may fail."
fi

mkdir -p "$ROOTS_OUT"
mkdir -p "$BUILD_DIR"

################################################################################
# HELPER FUNCTIONS
################################################################################

# Run an autoconf project against the Darwin cross-compiler.
#   build_autoconf <src_dir> <project_name> [extra_configure_args...]
build_autoconf() {
    _src="$1"; _name="$2"; shift 2
    _bdir="$BUILD_DIR/$_name"
    _dstroot="$BUILD_DIR/${_name}-DSTROOT"
    mkdir -p "$_bdir" "$_dstroot"

    # Export CC/CXX as environment variables so that configure picks them up
    # without treating them as host-triple positional arguments.
    echo "  Running ./configure"
    (cd "$_bdir" && \
     env \
         CC="$CC" CXX="$CXX" \
         CFLAGS="$EXTRA_CFLAGS" CXXFLAGS="$EXTRA_CFLAGS" \
         LDFLAGS="-L$DARWIN_SDK/usr/lib" \
         AR="$AR" RANLIB="$RANLIB" STRIP="$STRIP" \
     "$_src/configure" \
         --host="$DARWIN_TARGET" \
         --build="$(gcc -dumpmachine 2>/dev/null || echo x86_64-linux-gnu)" \
         --prefix=/usr \
         "$@")

    echo "  Running make"
    make -C "$_bdir" -j"$(nproc)"

    echo "  Running make install"
    make -C "$_bdir" install DESTDIR="$_dstroot"

    package_root "$_name" "$_dstroot"
}

# Compile a set of C files directly with clang (for projects without autoconf).
#   build_c_files <project_name> <dstroot_populate_function>
# The caller must define a function named "populate_<project_name>_dstroot"
# that receives the DSTROOT path as $1 and populates it.
build_c_files() {
    _name="$1"
    _dstroot="$BUILD_DIR/${_name}-DSTROOT"
    mkdir -p "$_dstroot"
    "populate_${_name}_dstroot" "$_dstroot"
    package_root "$_name" "$_dstroot"
}

# Package a DSTROOT directory into a .root.tar.gz in ROOTS_OUT.
#   package_root <project_name> <dstroot_path>
package_root() {
    _name="$1"
    _dstroot="$2"
    _out="$ROOTS_OUT/${_name}.root.tar.gz"
    echo "  Packaging -> $( basename "$_out" )"
    tar czpf "$_out" -C "$_dstroot" .
    echo "  [done] $_out"
}

################################################################################
# BUILD FUNCTIONS — one per project
################################################################################

build_libelf() {
    echo "=== Building: libelf ==="
    _src="$SRC_THIRD/libelf-3/libelf"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }
    build_autoconf "$_src" libelf \
        --enable-shared --enable-static \
        --includedir=/usr/include
}

build_libdwarf() {
    echo "=== Building: libdwarf ==="
    _src="$SRC_THIRD/libdwarf-20081013"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/libdwarf"
    _dstroot="$BUILD_DIR/libdwarf-DSTROOT"
    mkdir -p "$_dstroot/usr/lib" "$_dstroot/usr/include" "$_dstroot/usr/bin"

    # libdwarf uses its own non-autoconf Makefile; invoke it with cross-compile vars.
    make -C "$_src" \
        SRCROOT="$_src" \
        OBJROOT="$_bdir" \
        DSTROOT="$_dstroot" \
        CC="$CC" \
        RC_CFLAGS="$EXTRA_CFLAGS" \
        -j"$(nproc)" || true

    package_root libdwarf "$_dstroot"
}

