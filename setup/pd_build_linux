build_CF() {
    echo "=== Building: CF (CoreFoundation) ==="
    _src="$SRC_APPLE/CF"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/CF"
    _dstroot="$BUILD_DIR/CF-DSTROOT"
    _objbase="$_bdir/objects"
    mkdir -p "$_objbase/normal" "$_objbase/CoreFoundation" "$_dstroot"

    # CoreFoundation uses Objective-C + C, compiles to a single .dylib.
    # We omit -arch flags (single i386 target) and replace GCC-only flags.
    _all_c=$(cd "$_src" && ls ./*.c)

    # Copy headers for -I
    cp "$_src/"*.h "$_objbase/CoreFoundation/"

    _cflags="$EXTRA_CFLAGS \
        -I$_objbase \
        -c -pipe -std=gnu99 -g -Wno-deprecated-declarations \
        -mmacosx-version-min=10.5 \
        -DCF_BUILDING_CF=1 -DDEPLOYMENT_TARGET_MACOSX=1 \
        -DMAC_OS_X_VERSION_MAX_ALLOWED=MAC_OS_X_VERSION_10_5 \
        -DU_SHOW_DRAFT_API=1 -DVERSION=476.10 -O2"

    echo "  Compiling CF sources..."
    _objs=""
    for _f in $_all_c; do
        _base=$(basename "$_f" .c)
        _obj="$_objbase/normal/${_base}.o"
        $CC $_cflags "$_src/$_f" -o "$_obj" 2>&1 | head -5 || true
        _objs="$_objs $_obj"
    done

    _unicode=""
    case "$(uname -m)" in
        i386|i686) _unicode="CFUnicodeData-L.mapping" ;;
        *)         _unicode="CFUnicodeData-L.mapping" ;;  # default to little-endian
    esac

    echo "  Linking CoreFoundation.dylib..."
    $CC -dynamiclib \
        -mmacosx-version-min=10.5 \
        -install_name /System/Library/Frameworks/CoreFoundation.framework/Versions/A/CoreFoundation \
        -compatibility_version 150 \
        -current_version 476 \
        -Wl,-segcreate,__UNICODE,__csbitmaps,"$_src/CFCharacterSetBitmaps.bitmap" \
        -Wl,-segcreate,__UNICODE,__properties,"$_src/CFUniCharPropertyDatabase.data" \
        -Wl,-segcreate,__UNICODE,__data,"$_src/$_unicode" \
        $_objs \
        -licucore \
        -lobjc \
        -o "$_objbase/CoreFoundation" 2>&1 | head -10 || true

    # Install into a framework layout.
    _fwroot="$_dstroot/System/Library/Frameworks/CoreFoundation.framework"
    mkdir -p "$_fwroot/Versions/A/Headers" \
             "$_fwroot/Versions/A/PrivateHeaders" \
             "$_fwroot/Versions/A/Resources/en.lproj"
    ln -sf A          "$_fwroot/Versions/Current"
    ln -sf Versions/Current/Headers        "$_fwroot/Headers"
    ln -sf Versions/Current/PrivateHeaders "$_fwroot/PrivateHeaders"
    ln -sf Versions/Current/Resources      "$_fwroot/Resources"
    ln -sf Versions/Current/CoreFoundation "$_fwroot/CoreFoundation"

    cp "$_src/Info.plist" "$_fwroot/Versions/A/Resources/"

    # Public headers
    for _h in CFArray CFBag CFBase CFBinaryHeap CFBitVector CFBundle CFByteOrder \
               CFCalendar CFCharacterSet CFData CFDate CFDateFormatter CFDictionary \
               CFError CFLocale CFMachPort CFMessagePort CFNumber CFNumberFormatter \
               CFPlugIn CFPlugInCOM CFPreferences CFPropertyList CFRunLoop CFSet \
               CFSocket CFStream CFString CFStringEncodingExt CFTimeZone CFTree \
               CFURL CFURLAccess CFUUID CFUserNotification CFXMLNode CFXMLParser \
               CoreFoundation; do
        [ -f "$_src/${_h}.h" ] && cp "$_src/${_h}.h" "$_fwroot/Versions/A/Headers/"
    done

    # Private headers
    for _h in CFBundlePriv CFCharacterSetPriv CFError_Private CFLogUtilities \
               CFPriv CFRuntime CFStorage CFStreamAbstract CFStreamPriv \
               CFStreamInternal CFStringDefaultEncoding CFStringEncodingConverter \
               CFStringEncodingConverterExt CFUniChar CFUnicodeDecomposition \
               CFUnicodePrecomposition ForFoundationOnly; do
        [ -f "$_src/${_h}.h" ] && cp "$_src/${_h}.h" "$_fwroot/Versions/A/PrivateHeaders/"
    done

    [ -f "$_objbase/CoreFoundation" ] && \
        cp "$_objbase/CoreFoundation" "$_fwroot/Versions/A/CoreFoundation"

    package_root CF "$_dstroot"
}

build_launchd() {
    echo "=== Building: launchd ==="
    _src="$SRC_APPLE/launchd_258.18/launchd"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    # launchd needs CoreFoundation, mach, IOKit, Security, bsm, dns_sd.
    # These are available from the Darwin SDK assembled in the Dockerfile.
    _extra="-I$_src/src -I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"

    build_autoconf "$_src" launchd \
        --sbindir=/sbin \
        --bindir=/bin \
        --sysconfdir=/private/etc \
        CFLAGS="$_extra" \
        CXXFLAGS="$_extra"
}

build_IOKitUser() {
    echo "=== Building: IOKitUser ==="
    _src="$SRC_APPLE/IOKitUser"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/IOKitUser"
    _dstroot="$BUILD_DIR/IOKitUser-DSTROOT"
    mkdir -p "$_bdir" "$_dstroot/usr/lib" "$_dstroot/usr/include/IOKit"

    # IOKitUser builds IOKit.framework (user-space API to the IOKit kernel).
    # Key sources: IOKitLib.c, IOCFBundle.c, IOCFPlugIn.c, IOCFSerialize.c,
    #              IOCFUnserialize.tab.c, IOBundle.c, iokitmig.c, etc.
    _srcs="IOKitLib.c IOCFBundle.c IOCFPlugIn.c IOCFSerialize.c \
           IOBundle.c iokitmig.c IOCFURLAccess.c IOSystemConfiguration.c \
           IODataQueueClient.c"

    _iflags="-I$_src -I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"

    for _f in $_srcs; do
        [ -f "$_src/$_f" ] || continue
        $CC -c "$_src/$_f" \
            $_iflags \
            -mmacosx-version-min=10.5 -O2 \
            -o "$_bdir/$(basename "$_f" .c).o" 2>&1 | head -3 || true
    done

    _objs=$(ls "$_bdir"/*.o 2>/dev/null)
    if [ -n "$_objs" ]; then
        $CC -dynamiclib \
            -install_name /System/Library/Frameworks/IOKit.framework/Versions/A/IOKit \
            -compatibility_version 1 -current_version 1 \
            $_objs \
            -framework CoreFoundation \
            -o "$_bdir/IOKit" 2>&1 | head -5 || true
    fi

    # Install headers.
    mkdir -p "$_dstroot/System/Library/Frameworks/IOKit.framework/Versions/A/Headers"
    cp "$_src/"*.h "$_dstroot/System/Library/Frameworks/IOKit.framework/Versions/A/Headers/" \
        2>/dev/null || true

    [ -f "$_bdir/IOKit" ] && \
        cp "$_bdir/IOKit" \
           "$_dstroot/System/Library/Frameworks/IOKit.framework/Versions/A/"

    package_root IOKitUser "$_dstroot"
}

build_IOHIDFamily() {
    echo "=== Building: IOHIDFamily (kext) ==="
    _src="$SRC_APPLE/IOHIDFamily"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _dstroot="$BUILD_DIR/IOHIDFamily-DSTROOT"
    mkdir -p "$_dstroot"

    # IOHIDFamily is a kernel extension (kext); its .cpp/.c files compile as
    # KEXT source (linking against the kernel-extension ABI, not user-space).
    # Kernel extensions cannot be meaningfully cross-compiled without the full
    # XNU kext SDK (Kernel.framework + KPI headers).  We install the public
    # headers and user-library portion here; the kext binary itself ships in
    # the pre-built xnu.root.tar.gz.
    mkdir -p "$_dstroot/System/Library/Extensions/IOHIDFamily.kext/Contents"
    if [ -d "$_src/IOHIDFamily" ]; then
        cp -r "$_src/IOHIDFamily" \
              "$_dstroot/System/Library/Extensions/IOHIDFamily.kext/Contents/Resources" \
              2>/dev/null || true
    fi

    package_root IOHIDFamily "$_dstroot"
}

build_IOAudioFamily() {
    echo "=== Building: IOAudioFamily (kext headers) ==="
    _src="$SRC_APPLE/IOAudioFamily"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _dstroot="$BUILD_DIR/IOAudioFamily-DSTROOT"
    mkdir -p "$_dstroot/System/Library/Extensions"

    # Same as IOHIDFamily: install headers; kext binary ships in xnu.root.
    mkdir -p "$_dstroot/System/Library/Frameworks/CoreAudio.framework/Headers"
    find "$_src" -name "*.h" -not -path "*/Examples/*" \
        -exec cp {} "$_dstroot/System/Library/Frameworks/CoreAudio.framework/Headers/" \; \
        2>/dev/null || true

    package_root IOAudioFamily "$_dstroot"
}

build_kext_tools() {
    echo "=== Building: kext_tools ==="
    _src="$SRC_APPLE/kext_tools"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/kext_tools"
    _dstroot="$BUILD_DIR/kext_tools-DSTROOT"
    mkdir -p "$_bdir" "$_dstroot/sbin" "$_dstroot/usr/sbin"

    # kext_tools contains: kextd, kextload, kextunload, kextstat, kextcache.
    # They all depend on IOKit + CoreFoundation.
    _iflags="-I$_src -I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"
    _common="arch.c QEQuery.c"

    for _tool in kextd kextload kextunload kextstat kextcache; do
        _main="${_tool}.c"
        [ -f "$_src/$_main" ] || continue

        # Gather the C files that belong to this tool (simplification: compile all
        # .c files and let the linker discard unused symbols).
        _srcs=$(cd "$_src" && ls ./*.c 2>/dev/null | tr '\n' ' ')
        _objs=""
        for _f in $_srcs; do
            _o="$_bdir/${_tool}_$(basename "$_f" .c).o"
            $CC -c "$_src/$_f" \
                $_iflags \
                -mmacosx-version-min=10.5 -O2 \
                -o "$_o" 2>&1 | head -2 || true
            [ -f "$_o" ] && _objs="$_objs $_o"
        done
        $CC $_objs \
            -framework IOKit \
            -framework CoreFoundation \
            -o "$_dstroot/sbin/$_tool" 2>&1 | head -3 || true
    done

    package_root kext_tools "$_dstroot"
}

build_configd() {
    echo "=== Building: configd ==="
    _src="$SRC_APPLE/configd"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/configd"
    _dstroot="$BUILD_DIR/configd-DSTROOT"
    mkdir -p "$_bdir" "$_dstroot/sbin"

    # configd is the System Configuration daemon + framework.
    # It uses CoreFoundation, SystemConfiguration, and Mach IPC.
    _iflags="-I$_src -I$_src/configd.tproj \
             -I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"

    _srcs=$(cd "$_src/configd.tproj" 2>/dev/null && ls ./*.c 2>/dev/null | tr '\n' ' ')
    _objs=""
    for _f in $_srcs; do
        _o="$_bdir/$(basename "$_f" .c).o"
        $CC -c "$_src/configd.tproj/$_f" \
            $_iflags \
            -mmacosx-version-min=10.5 -O2 \
            -o "$_o" 2>&1 | head -2 || true
        [ -f "$_o" ] && _objs="$_objs $_o"
    done
    $CC $_objs \
        -framework CoreFoundation \
        -framework SystemConfiguration \
        -o "$_dstroot/sbin/configd" 2>&1 | head -3 || true

    package_root configd "$_dstroot"
}

build_mDNSResponder() {
    echo "=== Building: mDNSResponder ==="
    _src="$SRC_APPLE/mDNSResponder"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    _bdir="$BUILD_DIR/mDNSResponder"
    _dstroot="$BUILD_DIR/mDNSResponder-DSTROOT"
    mkdir -p "$_bdir" "$_dstroot/usr/sbin" "$_dstroot/usr/lib"

    # mDNSResponder ships mDNSPosix (Linux-native) and mDNSMacOSX (Darwin).
    # For the Darwin target image we want mDNSMacOSX.
    _posix="$_src/mDNSPosix"
    _shared="$_src/mDNSCore"

    # Compile the shared mDNSCore sources.
    _iflags="-I$_src/mDNSCore -I$_src/mDNSShared \
             -I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"
    _srcs="$_shared/mDNS.c \
           $_shared/DNSDigest.c \
           $_shared/uDNS.c \
           $_src/mDNSShared/dnssd_clientshim.c \
           $_src/mDNSShared/mDNSDebug.c"

    _objs=""
    for _f in $_srcs; do
        [ -f "$_f" ] || continue
        _o="$_bdir/$(basename "$_f" .c).o"
        $CC -c "$_f" $_iflags -mmacosx-version-min=10.5 -O2 \
            -o "$_o" 2>&1 | head -2 || true
        [ -f "$_o" ] && _objs="$_objs $_o"
    done

    $CC $_objs \
        -framework CoreFoundation \
        -o "$_dstroot/usr/sbin/mDNSResponder" 2>&1 | head -3 || true

    package_root mDNSResponder "$_dstroot"
}

