################################################################################

# Dependency-ordered list of all projects with patched source in this repo.
ALL_PROJECTS="
    libelf
    libdwarf
    gnutar
    iodbc
    CF
    IOKitUser
    IOHIDFamily
    IOAudioFamily
    kext_tools
    configd
    mDNSResponder
    bless
    at_cmds
    ipv6configuration
    Tokend
    libsecurity_apple_csp
    libsecurity_filevault
    dtrace
    launchd
"

# If specific projects were named on the command line, build only those.
if [ $# -gt 0 ]; then
    BUILD_LIST="$*"
else
    BUILD_LIST="$ALL_PROJECTS"
fi

echo "==> Projects to build: $(echo "$BUILD_LIST" | tr '\n' ' ')"
echo ""

FAILED=""
for _proj in $BUILD_LIST; do
    "build_${_proj}" 2>&1 || FAILED="$FAILED $_proj"
done

rm -rf "$BUILD_DIR"

echo ""
if [ -n "$FAILED" ]; then
    echo "==> pd_build_linux finished with errors in:$FAILED"
    echo "    (Partial failures are expected without a complete Darwin SDK.)"
    echo "    Successfully built roots are in puredarwin.roots/Roots/9J61pd1/"
    exit 1
else
    echo "==> pd_build_linux complete."
    echo "    Roots written to: puredarwin.roots/Roots/9J61pd1/"
    echo ""
    echo "    Next step — assemble the disk image:"
    echo "      sudo ./setup/pd_setup_linux puredarwin.vmwarevm PureDarwin"
fi
