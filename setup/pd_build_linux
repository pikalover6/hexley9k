build_at_cmds() {
    echo "=== Building: at_cmds ==="
    _src="$SRC_APPLE/at_cmds"
    [ -d "$_src" ] || { echo "  SKIP: source not found at $_src"; return 0; }

    # at_cmds uses AppleTalk network headers (netat/).
    # Compile the individual tools (atprint, atlookup, etc.).
    _dstroot="$BUILD_DIR/at_cmds-DSTROOT"
    mkdir -p "$_dstroot/usr/bin"

    _iflags="-I$DARWIN_SDK/usr/include $EXTRA_CFLAGS"

    for _tdir in "$_src/"*.tproj; do
        [ -d "$_tdir" ] || continue
        _tname=$(basename "$_tdir" .tproj)
        _srcs=$(cd "$_tdir" && ls ./*.c 2>/dev/null | tr '\n' ' ')
        [ -z "$_srcs" ] && continue

        _bdir="$BUILD_DIR/at_cmds_${_tname}"
        mkdir -p "$_bdir"
        _objs=""
        for _f in $_srcs; do
            _o="$_bdir/$(basename "$_f" .c).o"
            $CC -c "$_tdir/$_f" $_iflags -mmacosx-version-min=10.5 -O2 \
                -o "$_o" 2>&1 | head -2 || true
            [ -f "$_o" ] && _objs="$_objs $_o"
        done
        $CC $_objs -o "$_dstroot/usr/bin/$_tname" 2>&1 | head -2 || true
    done

    package_root at_cmds "$_dstroot"
}

