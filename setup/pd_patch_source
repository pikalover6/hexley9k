# mDNSResponder  (tag: mDNSResponder-176.2)
#
# Three of the five patches use paths containing "../" (e.g.
# mDNSMacOSX/../mDNSCore/mDNSEmbeddedAPI.h).  GNU patch refuses to process
# such paths as a security measure ("potentially dangerous file name").
# Those three patches are applied as inline sed edits instead, targeting the
# resolved canonical paths directly.
# ===========================================================================
echo "--- mDNSResponder ---"
apply_patches apple/mDNSResponder \
    mDNSResponder-176.2.daemon.c.p1.patch \
    mDNSResponder-176.2.mDNSMacOSX.c.p1.patch

# mDNSEmbeddedAPI.h: comment out two size-check compile-time assertions that
# fail on PureDarwin because struct sizes differ from Apple's internal build.
_f="$SOURCE_DIR/apple/mDNSResponder/mDNSCore/mDNSEmbeddedAPI.h"
if grep -q 'char sizecheck_DNSQuestion' "$_f" 2>/dev/null; then
    echo "  Applying mDNSResponder-176.2.mDNSEmbeddedAPI.h (inline, ../  path workaround)"
    sed -i.orig \
        -e 's/^[[:space:]]*char sizecheck_DNSQuestion/	\/\/char sizecheck_DNSQuestion/' \
        -e 's/^[[:space:]]*char sizecheck_ZoneData/	\/\/char sizecheck_ZoneData/' \
        "$_f"
else
    echo "  [skip] mDNSEmbeddedAPI.h already patched"
fi

# uDNS.c: comment out one size-check assertion.
_f="$SOURCE_DIR/apple/mDNSResponder/mDNSCore/uDNS.c"
