#
# pd_patch_source
#
# Applies every patch from patches/ to the corresponding source tree that
# was placed under source/ by pd_fetch_source.
#
# All patches are in unified-diff format and use -p1 strip level, meaning
# the leading directory component (e.g. "configd-212.2/") is stripped and
# the patch is applied relative to the project's source root.
#
# Usage:
#   cd <repo-root>          # or setup/
#   ./setup/pd_patch_source
#
# Run pd_fetch_source first.
# Then run pd_build_source (on macOS) after this script.
#
# Exit status:
#   0  - all patches applied (or already applied)
#   1  - one or more patches failed; details are printed inline
#

set -e

# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")"; pwd)"
case "$SCRIPT_DIR" in
    */setup) REPO_ROOT="$(dirname "$SCRIPT_DIR")" ;;
    *)       REPO_ROOT="$SCRIPT_DIR" ;;
esac

PATCH_DIR="$REPO_ROOT/patches"
SOURCE_DIR="$REPO_ROOT/source"

echo "==> pd_patch_source"
echo "    Repo root : $REPO_ROOT"
echo "    Patch dir : $PATCH_DIR"
echo "    Source dir: $SOURCE_DIR"
echo ""

ERRORS=0

# ---------------------------------------------------------------------------
# apply_patches <source-subdir> <patch-file> [<patch-file> ...]
#
# Applies one or more patches to the directory at source/<source-subdir>.
# Each patch is applied with "patch -p1 --forward --batch".
#
#   --forward  : skip hunks that appear already applied (idempotent)
#   --batch    : choose the best target file automatically; do not prompt
#
# Note on .origin files: several patches were generated by diffing a
# ".origin" backup against the modified file, so the "---" header contains
# a ".origin" suffix (e.g. "--- SCDPrivate.c.origin").  When ".origin"
# does not exist in the clean source tree, patch automatically falls back to
# the "+++ " filename, which is correct behaviour for our purposes.
# ---------------------------------------------------------------------------
apply_patches() {
    _subdir="$1"
    shift
    _src="$SOURCE_DIR/$_subdir"

    if [ ! -d "$_src" ]; then
        echo "  [MISSING] source/$_subdir -- skipping (run pd_fetch_source first)"
        ERRORS=$((ERRORS + 1))
        return
    fi

    for _pfile in "$@"; do
        _ppath="$PATCH_DIR/$_pfile"
        if [ ! -f "$_ppath" ]; then
            echo "  [MISSING] patches/$_pfile"
            ERRORS=$((ERRORS + 1))
            continue
        fi

        echo "  Applying $PATCH_DIR/$_pfile -> source/$_subdir"
        # Run patch from inside the source directory so -p1 resolves correctly.
        (cd "$_src" && patch -p1 --forward --batch < "$_ppath") \
            || { echo "  ERROR: patch failed: $_pfile"; ERRORS=$((ERRORS + 1)); }
    done
}

